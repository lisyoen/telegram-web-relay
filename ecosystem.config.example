module.exports = {
  apps: [{
    name: 'telegram-web-relay',
    script: 'server.js',
    cwd: __dirname,
    env: {
      NODE_ENV: 'production',
      PORT: 9087,
      TELEGRAM_API_ID: '',
      TELEGRAM_API_HASH: '',
      // Optional: path to the built telegram-web-relay-client dist
      // V2_DIST_PATH: '../telegram-web-relay-client/dist',
      // Optional: legacy v1 host (serves public/ when request host matches)
      // V1_HOST: ''
    },
    instances: 1,
    exec_mode: 'fork',
    autorestart: true,
    watch: false,
    max_memory_restart: '300M'
  }]
};
