# Telegram API credentials - get from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# HTTP port
PORT=9087

# Session cookie secret. Change this in production.
SESSION_SECRET=change-me

# (optional) legacy v1 host: if set and request host matches, serve v1 static (public/). unset = always serve v2.
V1_HOST=

# (optional) path to built v2 client dist (telegram-web-relay-client)
V2_DIST_PATH=../telegram-web-relay-client/dist

# (optional) archive SQLite path. Default is ./db/chat-archive.sqlite and is created at runtime.
# ARCHIVE_DB_PATH=

# (optional) comma-separated chat IDs for target/main-chat features. empty = disabled.
# TARGET_CHATS=
# MAIN_CHATS=
